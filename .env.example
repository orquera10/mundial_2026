# Scraper configurable. Para el fixture del Mundial usa la pagina de partidos de Flashscore.
SCRAPER_BASE_URL=https://www.flashscore.com.ar/futbol/mundial/campeonato-del-mundo/partidos/
SCRAPER_USER_AGENT=Mundial2026Bot/1.0 (+https://mundial26.darioapp.online)
SCRAPER_TIMEOUT_SECONDS=15
SCRAPER_FLASHSCORE_FSIGN=SW9D1eZo
SCRAPER_FLASHSCORE_TODAY_FEED=f_1_0_2_es-ar_1

# Worker opcional para Coolify: python manage.py poll_results --fase-previa
RESULTS_POLL_INTERVAL=300
# RESULTS_POLL_DATE_FROM=2026-06-11
# RESULTS_POLL_DATE_TO=2026-06-30

# Job Coolify recomendado cada 5 minutos: python scripts/sync_results_once.py
# Consulta la API para partidos que ya empezaron y no finalizaron.
# Sigue revisando partidos no finalizados durante esta ventana posterior al inicio.
RESULTS_SYNC_FOLLOW_HOURS=12
