# Copia este archivo como .env y completa los valores reales.

SECRET_KEY=django-insecure-cambiar-en-produccion
DEBUG=False
ALLOWED_HOSTS=mundial26.darioapp.online
CSRF_TRUSTED_ORIGINS=https://mundial26.darioapp.online
