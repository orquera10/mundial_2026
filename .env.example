# ALLOWED_HOSTS=mundial26.darioapp.online,localhost,127.0.0.1,0.0.0.0
# CSRF_TRUSTED_ORIGINS=https://mundial26.darioapp.online,http://localhost:8000,http://127.0.0.1:8000,http://0.0.0.0:8000
USE_X_FORWARDED_HOST=True
PORT=8000
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60

DB_ENGINE=postgresql
DB_NAME=mundial_2026
